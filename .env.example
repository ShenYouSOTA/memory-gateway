# AI Memory Gateway 环境变量配置示例
# 复制此文件为 .env 并填入你的配置

# ========== 必填 ==========
# LLM API Key
API_KEY=sk-xxx

# LLM API 地址
API_BASE_URL=https://openrouter.ai/api/v1/chat/completions

# 默认模型
DEFAULT_MODEL=anthropic/claude-sonnet-4

# 服务端口
PORT=8000

# ========== 数据库（记忆功能必需） ==========
# PostgreSQL 连接字符串
# DATABASE_URL=postgresql://user:password@host:port/database

# ========== 记忆系统 ==========
# 开启记忆功能
MEMORY_ENABLED=false

# 记忆提取模型（推荐便宜的小模型）
MEMORY_MODEL=anthropic/claude-haiku-4

# 每次注入的最大记忆条数
MAX_MEMORIES_INJECT=15

# 记忆搜索最低分数阈值（0=不过滤）
MIN_SCORE_THRESHOLD=0.15

# 记忆提取间隔（0=禁用/1=每轮/N=每N轮）
MEMORY_EXTRACT_INTERVAL=1

# 记忆提取+注入总开关（false时只存消息不提取记忆）
# MEMORY_EXTRACT_ENABLED=true

# 时区偏移（小时），用于记忆注入时的日期显示
TIMEZONE_HOURS=8

# ========== 分区缓存 ==========
# 开启分区缓存
CACHE_PARTITION_ENABLED=false

# 轮转周期（轮数）
CACHE_PARTITION_X=15

# 摘要压缩模型
CACHE_SUMMARY_MODEL=anthropic/claude-haiku-4

# 固定的 session ID
# PARTITION_SESSION_ID=my-thread

# 轮转触发方式：rounds（按轮次）或 time（按时间窗口）
# CACHE_PARTITION_TRIGGER=rounds

# 时间窗口（分钟），仅 trigger=time 时生效
# CACHE_PARTITION_WINDOW=30

# ========== 向量搜索（可选） ==========
# 开启向量搜索
MEMORY_VECTOR_ENABLED=false

# Embedding API Key
# EMBEDDING_API_KEY=sk-xxx

# Embedding API 地址
# EMBEDDING_BASE_URL=https://api.openai.com/v1

# Embedding 模型
# EMBEDDING_MODEL=text-embedding-3-small

# 向量维度
# EMBEDDING_DIM=256

# ========== zvec 向量数据库（可选） ==========
# 使用 zvec 替代 pgvector（更轻量、部署更简单）
ZVEC_ENABLED=false

# zvec 数据存储路径
# ZVEC_PATH=./zvec_data

# 混合搜索权重（仅 zvec 模式生效）
# MEMORY_HW_KEYWORD=0.35
# MEMORY_HW_SEMANTIC=0.35
# MEMORY_HW_IMPORTANCE=0.15
# MEMORY_HW_RECENCY=0.15

# 语义搜索最低相似度阈值
# MEMORY_SEMANTIC_THRESHOLD=0.5

# ========== 安全 ==========
# 网关鉴权密钥（设置后所有 API 端点需要携带此密钥）
# GATEWAY_SECRET=your-secret-key

# ========== 其他 ==========
# 强制所有请求走流式传输
# FORCE_STREAM=false

# 推理强度（low/medium/high），注入请求启用思维链
# REASONING_EFFORT=
